{{ 'age-verifier.css' | asset_url | stylesheet_tag }}
<script src="{{ 'age-verifier.js' | asset_url }}" defer="defer"></script>

<style>
  #shopify-section-{{ section.id }} {
    --age-text: {{ section.settings.color_drawer_text.rgb }};
    --age-bg: {{ section.settings.color_drawer_background.rgb }};
    --age-overlay: {{ section.settings.color_drawer_overlay.rgb }};
    --age-btn-bg: {{ section.settings.color_drawer_button_background.rgb }};
    --age-btn-text: {{ section.settings.color_drawer_button_text.rgb }};
  }
  .age-modal .overlay {
    background: rgb({{ section.settings.color_drawer_overlay.rgb }});
  }
  .age-modal .age-verifier__card {
    background: rgb({{ section.settings.color_drawer_background.rgb }});
  }
  .age-verifier__heading {
    color: rgb({{ section.settings.color_drawer_text.rgb }});
  }
  .age-verifier__question {
    color: rgb({{ section.settings.color_drawer_text.rgb }});
  }
  .age-verifier__btn:focus-visible {
    outline: 2px solid rgb({{ section.settings.color_drawer_text.rgb }});
  }
  .age-verifier__btn--yes {
    background: rgb({{ section.settings.color_drawer_button_background.rgb }});
    color: rgb({{ section.settings.color_drawer_button_text.rgb }});
  }
  .age-verifier__btn--no {
    background: transparent;
    color: rgb({{ section.settings.color_drawer_text.rgb }});
    border: 1.5px solid rgb({{ section.settings.color_drawer_text.rgb }});
  }
</style>

<age-verifier id="AgeVerifier" class="age-modal"
  data-delay="{{ section.settings.delay }}"
  data-expiry="{{ section.settings.expiry }}"
  data-test-mode="{% if section.settings.mode == 'testing' %}true{% else %}false{% endif %}"
  role="dialog"
  aria-labelledby="age-verifier-heading-{{ section.id }}"
  aria-modal="true"
  shopify-design-mode
>
  <div class="age-verifier__overlay overlay fixed-overlay" aria-hidden="true"></div>

  <div class="age-verifier__card">
    <div class="age-verifier__content drawer__content">
      <div id="age-verifier-heading-{{ section.id }}" class="age-verifier__heading">
        {{ section.settings.heading | default: 'Confirm your age' }}
      </div>
      <p class="age-verifier__question">
        {{ section.settings.question | default: 'Are you 18 years old or older?' }}
      </p>
      <div class="age-verifier__buttons">
        <button type="button" class="age-verifier__btn age-verifier__btn--yes" aria-controls="AgeVerifier" aria-expanded="false">
          {% render 'icon', icon: 'accept', size: 'sm' %}
          <span>{{ section.settings.button_yes | default: 'Yes, I am' }}</span>
        </button>
        {%- if section.settings.button_no_link != blank -%}
          <a class="age-verifier__btn age-verifier__btn--no" href="{{ section.settings.button_no_link }}"{% if section.settings.button_no_external %} target="_blank" rel="noopener"{% endif %}>
            {% render 'icon', icon: 'decline', size: 'sm' %}
            <span>{{ section.settings.button_no | default: "No, I'm not" }}</span>
          </a>
        {%- else -%}
          <button type="button" class="age-verifier__btn age-verifier__btn--no">
            {% render 'icon', icon: 'decline', size: 'sm' %}
            <span>{{ section.settings.button_no | default: "No, I'm not" }}</span>
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</age-verifier>

{% schema %}
{
  "name": "Age Verifier Popup",
  "settings": [
    {
      "type": "range",
      "id": "delay",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Popup delay",
      "info": "Seconds before showing the popup after page load.",
      "default": 1
    },
    {
      "type": "select",
      "id": "mode",
      "options": [
        { "value": "enabled", "label": "Enabled" },
        { "value": "testing", "label": "Testing" }
      ],
      "default": "enabled",
      "label": "Mode",
      "info": "Testing shows the popup every time."
    },
    {
      "type": "range",
      "id": "expiry",
      "max": 90,
      "min": 7,
      "step": 1,
      "unit": "day",
      "label": "Cookie expiry",
      "default": 30
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Confirm your age"
    },
    {
      "type": "text",
      "id": "question",
      "label": "Question",
      "default": "Are you 18 years old or older?"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_yes",
      "label": "Accept button",
      "default": "Yes, I am"
    },
    {
      "type": "text",
      "id": "button_no",
      "label": "Decline button",
      "default": "No, I'm not"
    },
    {
      "type": "url",
      "id": "button_no_link",
      "label": "Decline button link"
    },
    {
      "type": "checkbox",
      "id": "button_no_external",
      "label": "Open decline link in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_drawer_text",
      "label": "Text color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "color_drawer_background",
      "label": "Popup background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_drawer_overlay",
      "label": "Overlay color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "color_drawer_button_background",
      "label": "Accept button background",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "color_drawer_button_text",
      "label": "Accept button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    { "name": "Age Verifier Popup" }
  ]
}
{% endschema %}
