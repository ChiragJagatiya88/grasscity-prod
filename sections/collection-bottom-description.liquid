{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% if collection.metafields.custom.bottom_description != blank %}
  <div class="page-width page-width--{{ section.settings.container }} section__container section-{{ section.id }}-padding">
    <div class="collection_bottom_des rte">
      {{ collection.metafields.custom.bottom_description | metafield_tag }}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Collection Bottom Desc",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "fixed",
          "label": "Fixed width"
        }
      ],
      "default": "fixed",
      "label": "Container width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Collection Bottom Desc"
    }
  ]
}
{% endschema %}
