<div class="section_{{ section.id }} {{ section.settings.section_class }}">
  <div class="{% if section.settings.enable_container %}container{% else %}container-fluid{% endif %}">
    <h2>{{ section.settings.sec_title }}</h2>

    {% assign offset = 0 %}
    <div class="demo-blocks">
      {% for block in section.blocks %}
        <div class="demo-block" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.blog.title }}</h3>
          <div class="main-blog__block main-blog__items f-grid f-grid--gap-{{ section.settings.column_gap }} f-grid--row-gap-{{ section.settings.row_gap }}">
            {%- for article in blog.articles offset: offset -%}
              <div class="f-column">
                {%- render 'card-article',
                  article: article,
                  show_tags: show_tags,
                  show_author: show_author,
                  show_date: show_date,
                  show_excerpt: show_excerpt,
                  show_button: show_button,
                  index: forloop.index,
                  title_size: section.settings.card_title_size,
                  button_style: 'btn--icon'
                -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>


{% style %}
  .section_{{ section.id }} {
    {% if section.settings.section_bg %} background: {{ section.settings.section_bg }};{% endif %}
    {% if section.settings.section_gradient_bg %} background: {{ section.settings.section_gradient_bg }};{% endif %}
    {% if section.settings.enable_custom_padding == true %}padding-block: {{ section.settings.padding_desk }};{% endif %}
  }
  @media screen and  (max-width: 767px) {
    .section_{{ section.id }} {
      {% if section.settings.enable_custom_padding == true %}padding-block: {{ section.settings.padding_mob }};{% endif %}
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "All Blogs",
  "class": "all_blogs",
  "settings": [
    { "type": "checkbox", "id": "enable_custom_class", "label": "Enable Custom Class" },
    { "type": "text", "id": "section_class", "label": "Custom Class For Section", "visible_if": "{{ section.settings.enable_custom_class == true }}" },
    
    { "type": "checkbox", "id": "enable_container", "label": "Enable Container" },

    { "type": "header", "content": "Section Content"},
    { "type": "text", "id": "sec_title", "label": "Section Title", "default": "Section Title" },

    { "type": "header", "content": "Color"},
    { "type": "color", "id": "section_bg", "label": "Section Background"},
    { "type": "color_background", "id": "section_gradient_bg", "label": "Section Gradient Background"},

    { "type": "header", "content": "Spacing"},
    { "type": "checkbox", "id": "enable_custom_padding", "label": "Enable Section Custom Padding"},
    { "type": "text", "id": "padding_desk", "label": "Padding Desktop", "default": "20px 20px", "visible_if": "{{ section.settings.enable_custom_padding == true }}"},
    { "type": "text", "id": "padding_mob", "label": "Padding Mobile", "default": "20px 20px", "visible_if": "{{ section.settings.enable_custom_padding == true }}"},
  ],
  "blocks": [
    {
      "name": "Item",
      "type": "item",
      "settings": [
        { "type": "blog", "id": "blog", "label": "Select blog Cetegory"}
      ]
    }
  ],
  "presets": [
    {
      "name": "All Blogs",
    }
  ]
}
{% endschema %}
