<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "@id": "{{ shop.url }}//#org",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }},
    "description": "Grasscity is a leading online smoke shop that offers the largest range of bongs, dab rigs, water pipes, glass pipes, bubblers, vaporizers and accessories.",
    "telephone": "+1 (888) 334-6363",
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": "+1 (888) 334-6363",
        "contactType": "customer service"
      }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6225 N Hollywood Blvd Ste 145",
      "addressRegion": "Las vegas",
      "postalCode": "89115",
      "addressCountry": "United States"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}/a/search/{search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% if template == 'product' %}
  {% assign current_variant = product.selected_or_first_available_variant %}
  {% assign single_product = product %}
  {% if product.variants.size == 1 %}
    {% if product.variants.first.metafields.custom.member_price == blank %}
      {% assign single_product = product %}
    {% else %}
      {% assign single_product = product.variants.first %}
    {% endif %}
  {% else %}
    {% assign selected_variant = product.selected_variant.id %}
    {% if selected_variant != blank %} {% endif %}
    {% for variant in product.variants %}
      {%- if variant.metafields.custom.member_price -%}
        {% assign single_product = variant %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",


      {% if product.metafields.yotpo.reviews_count and product.metafields.yotpo.reviews_average != "0" %}
        {% assign reviewcount = product.metafields.yotpo.reviews_count | plus: 0 %}
        {% assign average = product.metafields.yotpo.reviews_average | plus: 0 %}
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ average }}",
          "reviewCount": "{{ reviewcount }}"
        },
      {% endif %}


    "offers": [
      {
        "@type": "Offer",
        "price": "{{ single_product.price | money_without_currency }}",
        "priceCurrency": "{{ shop.currency }}",
        {% if single_product.available %}
        "availability": "https://schema.org/InStock",
        {% else %}
        "availability": "https://schema.org/OutOfStock",
        {% endif %}
        "description": "Non-member price"
      },
      {
        "@type": "Offer",
        "price": "{{ single_product.metafields.custom.member_price | default: 0 | times: 100 | money_without_currency }}",
        "priceCurrency": "{{ shop.currency }}",
        {% if single_product.available %}
        "availability": "https://schema.org/InStock",
        {% else %}
        "availability": "https://schema.org/OutOfStock",
        {% endif %}
        "description": "Member price"
      }
    ]

    }
  </script>
{% endif %}


