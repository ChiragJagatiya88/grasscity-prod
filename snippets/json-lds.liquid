{%- elsif template contains 'collection' and collection -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ shop.url }}"
      }

      {%- assign position = 1 -%}
      {%- assign custom_breadcrumbs = collection.metafields.custom.breadcrumbs.value -%}
      {%- if custom_breadcrumbs != blank -%}
        {%- for bc_collection in custom_breadcrumbs -%}
          {%- assign position = position | plus: 1 -%}
          ,{
            "@type": "ListItem",
            "position": {{ position }},
            "name": "{{ bc_collection.title | escape }}",
            "item": "{{ shop.url }}{{ bc_collection.url }}"
          }
        {%- endfor -%}
      {%- else -%}
        {%- assign position = position | plus: 1 -%}
        ,{
          "@type": "ListItem",
          "position": {{ position }},
          "name": "Collections",
          "item": "{{ shop.url }}/collections"
        }
      {%- endif -%}

      {%- assign position = position | plus: 1 -%}
      ,{
        "@type": "ListItem",
        "position": {{ position }},
        "name": "{{ collection.title | escape }}",
        "item": "{{ shop.url }}{{ collection.url }}"
      }
    ]
  }
  </script>

{%- elsif template contains 'product' and product -%}
  {%- liquid
    assign position = 1
    assign main_collection = nil
    assign sub_collection = nil
    assign collection_metaobjects = shop.metaobjects.collections.values

    # 1. Try to find Sub Collection first (Child)
    for entry in collection_metaobjects
      assign sub_list = entry.sub_collections.value

      for scol in sub_list
        if product.collections contains scol
          assign sub_collection = scol

          # Find Parent (Main Collection) from same metaobject
          assign main_list = entry.main_collections.value

          # Prefer main collection product actually belongs to
          for mcol in main_list
            if product.collections contains mcol
              assign main_collection = mcol
              break
            endif
          endfor

          # Fallback: first main collection
          if main_collection == nil
            assign main_collection = main_list | first
          endif

          break
        endif
      endfor

      if sub_collection
        break
      endif
    endfor

    # 2. If no Sub Collection found, try Main Collection only
    unless sub_collection
      for entry in collection_metaobjects
        assign main_list = entry.main_collections.value

        for mcol in main_list
          if product.collections contains mcol
            assign main_collection = mcol
            break
          endif
        endfor

        if main_collection
          break
        endif
      endfor
    endunless
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        }
        {%- if main_collection -%}
          ,{
            "@type": "ListItem",
            "position": {{ position | plus: 1 }},
            "name": "{{ main_collection.title | replace: '"', '' | replace: "'", '' | escape }}",
            "item": "{{ shop.url }}{{ main_collection.url }}"
          }
          {%- assign position = position | plus: 1 -%}
        {%- endif -%}

        {%- if sub_collection -%}
          ,{
            "@type": "ListItem",
            "position": {{ position | plus: 1 }},
            "name": "{{ sub_collection.title | replace: '"', '' | replace: "'", '' | escape }}",
            "item": "{{ shop.url }}{{ sub_collection.url }}"
          }
          {%- assign position = position | plus: 1 -%}
        {%- endif -%}

        ,{
          "@type": "ListItem",
          "position": {{ position | plus: 1 }},
          "name": "{{ product.title | replace: '"', '' | replace: "'", '' | escape }}",
          "item": "{{ shop.url }}{{ product.url }}"
        }
      ]
    }
  </script>
{%- endif -%}