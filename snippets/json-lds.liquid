<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "{{ shop.url }}//#org",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}",
    {% if settings.logo %}
      "logo": {
        "@type": "ImageObject",
        "url": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
        "width": 500,
        "height": 500
      },
    {% endif %}
    "sameAs": [
      {% if settings.social_twitter_link != blank %}{{ settings.social_twitter_link | json }},{% endif %}
      {% if settings.social_facebook_link != blank %}{{ settings.social_facebook_link | json }},{% endif %}
      {% if settings.social_pinterest_link != blank %}{{ settings.social_pinterest_link | json }},{% endif %}
      {% if settings.social_instagram_link != blank %}{{ settings.social_instagram_link | json }}{% endif %}
    ],
    "description": "Grasscity is a leading online smoke shop that offers the largest range of bongs, dab rigs, water pipes, glass pipes, bubblers, vaporizers and accessories.",
    "telephone": "+1 (888) 334-6363",
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": "+1 (888) 334-6363",
        "contactType": "customer service",
        "areaServed": "US",
        "availableLanguage": ["English"]
      }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6225 N Hollywood Blvd Ste 145",
      "addressLocality": "Las Vegas",
      "addressRegion": "NV",
      "postalCode": "89115",
      "addressCountry": "US"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "{{ shop.url }}/a/search/{search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "{{ shop.url }}//#website",
      "name": {{ shop.name | json }},
      "url": {{ request.origin | append: page.url | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ potential_action_target | json }}
        },
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@id": "{{ shop.url }}//#org"
      }
    }
  </script>
{%- endif -%}

{% if template == 'product' %}
  {% assign single_product = product %}
  {% if product.variants.size == 1 %}
    {% assign single_product = product.variants.first %}
  {% else %}
    {% for variant in product.variants %}
      {%- if variant.metafields.membership.price -%}
        {% assign single_product = variant %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% comment %} Determine market based on country code {% endcomment %}
  {% assign country_code = localization.country.iso_code | downcase %}
  {% assign market = 'us' %}

  {% comment %} Map country codes to markets {% endcomment %}
  {% case country_code %}
    {% when 'nl' %}
      {% assign market = 'nl' %}
    {% when 'fr' %}
      {% assign market = 'fr' %}
    {% when 'de' %}
      {% assign market = 'de' %}
    {% when 'gb', 'uk' %}
      {% assign market = 'uk' %}
    {% when 'us' %}
      {% assign market = 'us' %}
    {% else %}
      {% comment %} Check if it's an EU country (excluding NL, FR, DE, UK) {% endcomment %}
      {% assign eu_countries = 'at,be,bg,hr,cy,cz,dk,ee,fi,gr,hu,ie,it,lv,lt,lu,mt,pl,pt,ro,sk,si,es,se' | split: ',' %}
      {% if eu_countries contains country_code %}
        {% assign market = 'eu' %}
      {% else %}
        {% assign market = 'us' %}
      {% endif %}
  {% endcase %}

  {% comment %} Check if customer is B2B {% endcomment %}
  {% if customer and customer.tags contains 'B2B Droppery' or customer.tags contains 'Roor B2B' %}
    {% assign market = 'b2b' %}
  {% endif %}

  {% comment %} Get the JSON price metafield {% endcomment %}
  {%- assign price_json = single_product.metafields.membership.price -%}
  {% assign member_price_value = '' %}

  {% comment %} Extract member price from JSON metafield based on market {% endcomment %}
  {% if price_json != blank %}
    {% assign member_price_key = 'member_price_' | append: market %}
    
    {% comment %} Try direct JSON property access first (if Shopify stores as JSON type) {% endcomment %}
    {% assign member_price_value = price_json[member_price_key] %}
    
    {% comment %} If direct access didn't work, parse from JSON string {% endcomment %}
    {% if member_price_value == blank %}
      {% assign member_price_search = member_price_key | append: '":"' %}
      {% assign member_price_parts = price_json | split: member_price_search %}
      {% if member_price_parts.size > 1 %}
        {% assign member_price_split = member_price_parts[1] | split: '"' %}
        {% assign member_price_value = member_price_split[0] %}
      {% endif %}
    {% endif %}
  {% endif %}

  {% comment %} Calculate member price for JSON-LD (convert to cents, then format) {% endcomment %}
  {% if member_price_value != blank %}
    {% assign member_price_cents = member_price_value | times: 100 %}
  {% else %}
    {% assign member_price_cents = 0 %}
  {% endif %}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "@id": "{{ shop.url }}{{ product.url }}#product",
      "name": {{ product.title | json }},
      "url": "{{ shop.url }}{{ product.url }}",
      {% if product.description != blank %}
      "description": {{ product.description | strip_html | truncate: 100 | json }},
      {% endif %}
      {% if product.featured_image %}
      "image": [
        {{ product.featured_image | image_url: width: 1200 | prepend: "https:" | json }},
        {{ product.featured_image | image_url: width: 800 | prepend: "https:" | json }},
        {{ product.featured_image | image_url: width: 400 | prepend: "https:" | json }}
      ],
      {% elsif product.images.size > 0 %}
      "image": [
        {% for image in product.images limit: 3 %}
          {{ image | image_url: width: 1200 | prepend: "https:" | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      {% endif %}
      {% if product.vendor %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      {% endif %}
      {% if product.metafields.yotpo.reviews_count and product.metafields.yotpo.reviews_average != "0" %}
        {% assign reviewcount = product.metafields.yotpo.reviews_count | plus: 0 %}
        {% assign average = product.metafields.yotpo.reviews_average | plus: 0 %}
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ average }}",
          "reviewCount": "{{ reviewcount }}",
          "bestRating": "5",
          "worstRating": "1"
        },
      {% endif %}
      "offers": {
        "@type": "AggregateOffer",
        "offerCount": "{% if member_price_cents > 0 %}2{% else %}1{% endif %}",
        "lowPrice": "{% if member_price_cents > 0 %}{{ member_price_cents | money_without_currency }}{% else %}{{ single_product.price | money_without_currency }}{% endif %}",
        "highPrice": "{{ single_product.price | money_without_currency }}",
        "priceCurrency": "{{ shop.currency }}",
        "availability": "{% if single_product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "offers": [
          {
            "@type": "Offer",
            "price": "{{ single_product.price | money_without_currency }}",
            "priceCurrency": "{{ shop.currency }}",
            {% if single_product.available %}
            "availability": "https://schema.org/InStock",
            {% else %}
            "availability": "https://schema.org/OutOfStock",
            {% endif %}
            "url": "{{ shop.url }}{{ product.url }}",
            "priceValidUntil": "{{ 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' }}",
            "itemCondition": "https://schema.org/NewCondition",
            "description": "Non-member price"
          }{% if member_price_cents > 0 %},
          {
            "@type": "Offer",
            "price": "{{ member_price_cents | money_without_currency }}",
            "priceCurrency": "{{ shop.currency }}",
            {% if single_product.available %}
            "availability": "https://schema.org/InStock",
            {% else %}
            "availability": "https://schema.org/OutOfStock",
            {% endif %}
            "url": "{{ shop.url }}{{ product.url }}",
            "priceValidUntil": "{{ 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' }}",
            "itemCondition": "https://schema.org/NewCondition",
            "description": "Member price"
          }{% endif %}
        ]
      }
    }
  </script>
{% endif %}

{% comment %} Bread Crumb List {% endcomment %}
{%- if template == 'article' and article and blog -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ blog.title | escape }}",
          "item": "{{ shop.url }}{{ blog.url }}"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ article.title | escape }}",
          "item": "{{ shop.url }}{{ article.url }}"
        }
      ]
    }
  </script>
{%- elsif template == 'blog' and blog -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ blog.title | escape }}",
          "item": "{{ shop.url }}{{ blog.url }}"
        }
      ]
    }
  </script>
{%- elsif template contains 'page' and page -%}
  {% comment %} WebPage Schema for SEO {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": "{{ shop.url }}{{ page.url }}#webpage",
      "url": "{{ shop.url }}{{ page.url }}",
      "name": {{ page.title | json }},
      {% if page.content != blank %}
      "description": {{ page.content | strip_html | truncate: 100 | json }},
      {% elsif page.metafields.description %}
      "description": {{ page.metafields.description | json }},
      {% endif %}
      "inLanguage": "{{ request.locale.iso_code }}",
      "isPartOf": {
        "@id": "{{ shop.url }}//#website"
      },
      "about": {
        "@id": "{{ shop.url }}//#org"
      },
      "datePublished": "{{ page.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
      "dateModified": "{{ page.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
      "breadcrumb": {
        "@id": "{{ shop.url }}{{ page.url }}#breadcrumb"
      }
    }
  </script>
  
  {% comment %} BreadcrumbList Schema {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": "{{ shop.url }}{{ page.url }}#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ page.title | json }},
          "item": "{{ shop.url }}{{ page.url }}"
        }
      ]
    }
  </script>
{%- elsif template contains 'collection' and collection -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        }

        {%- assign position = 1 -%}
        {%- assign custom_breadcrumbs = collection.metafields.custom.breadcrumbs.value -%}
        {%- if custom_breadcrumbs != blank -%}
          {%- for bc_collection in custom_breadcrumbs -%}
            {%- assign position = position | plus: 1 -%}
            ,{
              "@type": "ListItem",
              "position": {{ position }},
              "name": "{{ bc_collection.title | escape }}",
              "item": "{{ shop.url }}{{ bc_collection.url }}"
            }
          {%- endfor -%}
        {%- else -%}
          {%- assign position = position | plus: 1 -%}
          ,{
            "@type": "ListItem",
            "position": {{ position }},
            "name": "Collections",
            "item": "{{ shop.url }}/collections"
          }
        {%- endif -%}

        {%- assign position = position | plus: 1 -%}
        ,{
          "@type": "ListItem",
          "position": {{ position }},
          "name": "{{ collection.title | escape }}",
          "item": "{{ shop.url }}{{ collection.url }}"
        }
      ]
    }
  </script>
{%- elsif template contains 'product' and product -%}
  {%- liquid
    assign position = 1
    assign main_collection = nil
    assign sub_collection = nil
    assign collection_metaobjects = shop.metaobjects.collections.values

    # 1. Try to find Sub Collection first (Child)
    for entry in collection_metaobjects
      assign sub_list = entry.sub_collections.value

      for scol in sub_list
        if product.collections contains scol
          assign sub_collection = scol

          # Find Parent (Main Collection) from same metaobject
          assign main_list = entry.main_collections.value

          # Prefer main collection product actually belongs to
          for mcol in main_list
            if product.collections contains mcol
              assign main_collection = mcol
              break
            endif
          endfor

          # Fallback: first main collection
          if main_collection == nil
            assign main_collection = main_list | first
          endif

          break
        endif
      endfor

      if sub_collection
        break
      endif
    endfor

    # 2. If no Sub Collection found, try Main Collection only
    unless sub_collection
      for entry in collection_metaobjects
        assign main_list = entry.main_collections.value

        for mcol in main_list
          if product.collections contains mcol
            assign main_collection = mcol
            break
          endif
        endfor

        if main_collection
          break
        endif
      endfor
    endunless
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        }
        {%- if main_collection -%}
          ,{
            "@type": "ListItem",
            "position": {{ position | plus: 1 }},
            "name": "{{ main_collection.title | replace: '"', '' | replace: "'", '' | escape }}",
            "item": "{{ shop.url }}{{ main_collection.url }}"
          }
          {%- assign position = position | plus: 1 -%}
        {%- endif -%}

        {%- if sub_collection -%}
          ,{
            "@type": "ListItem",
            "position": {{ position | plus: 1 }},
            "name": "{{ sub_collection.title | replace: '"', '' | replace: "'", '' | escape }}",
            "item": "{{ shop.url }}{{ sub_collection.url }}"
          }
          {%- assign position = position | plus: 1 -%}
        {%- endif -%}

        ,{
          "@type": "ListItem",
          "position": {{ position | plus: 1 }},
          "name": "{{ product.title | replace: '"', '' | replace: "'", '' | escape }}",
          "item": "{{ shop.url }}{{ product.url }}"
        }
      ]
    }
  </script>
{%- endif -%}