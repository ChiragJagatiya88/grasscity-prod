{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_image = page_image

  if request.page_type == 'product'
    assign og_type = 'product'
    unless og_image
      assign og_image = product.featured_image
    endunless
    unless og_description
      assign og_description = product.description | strip_html | truncate: 100
    endunless
  elsif request.page_type == 'article'
    assign og_type = 'article'
    unless og_image
      assign og_image = article.image
    endunless
    unless og_description
      assign og_description = article.excerpt | default: article.content | strip_html | truncate: 100
    endunless
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

{% comment %} Open Graph Meta Tags {% endcomment %}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">

{%- if og_image -%}
  {%- assign og_image_url = og_image | image_url: width: 1200 -%}
  <meta property="og:image" content="https:{{ og_image_url }}">
  <meta property="og:image:secure_url" content="https:{{ og_image_url }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ og_image.height | times: 1200 | divided_by: og_image.width }}">
  <meta property="og:image:alt" content="{{ og_title | escape }}">
{%- elsif settings.logo -%}
  {%- assign og_image_url = settings.logo | image_url: width: 1200 -%}
  <meta property="og:image" content="https:{{ og_image_url }}">
  <meta property="og:image:secure_url" content="https:{{ og_image_url }}">
  <meta property="og:image:alt" content="{{ shop.name | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <meta property="product:price:amount" content="{{ current_variant.price | money_without_currency | strip_html }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if current_variant.available %}in stock{% else %}out of stock{% endif %}">
  <meta property="product:condition" content="new">
  {%- if product.vendor -%}
    <meta property="product:brand" content="{{ product.vendor }}">
  {%- endif -%}
  {%- if product.type -%}
    <meta property="product:category" content="{{ product.type }}">
  {%- endif -%}
{%- elsif request.page_type == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  {%- if article.author -%}
    <meta property="article:author" content="{{ article.author }}">
  {%- endif -%}
  {%- if article.tags.size > 0 -%}
    {%- for tag in article.tags limit: 5 -%}
      <meta property="article:tag" content="{{ tag | escape }}">
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{% comment %} Twitter Card Meta Tags {% endcomment %}
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
  <meta name="twitter:creator" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ og_title | escape }}">
{%- elsif settings.logo -%}
  <meta name="twitter:image" content="https:{{ settings.logo | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ shop.name | escape }}">
{%- endif -%}
