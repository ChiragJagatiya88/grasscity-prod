{%- liquid
  assign schema_product = product
  if product_input != blank
    assign schema_product = product_input
  endif

  assign schema_variant = schema_product.selected_or_first_available_variant
  assign schema_currency = cart.currency.iso_code | default: shop.currency
  assign schema_url = shop.url | append: schema_product.url

  assign current_year = 'now' | date: '%Y' | plus: 0
  assign next_year = current_year | plus: 1
  assign price_valid_until = next_year | append: '-12-31'

  assign rating_value = blank
  assign review_count = 0

  if schema_product.metafields.yotpo.reviews_average != blank and schema_product.metafields.yotpo.reviews_count != blank
    assign yotpo_rating = schema_product.metafields.yotpo.reviews_average | plus: 0
    assign yotpo_count = schema_product.metafields.yotpo.reviews_count | plus: 0
    if yotpo_rating > 0 and yotpo_count > 0
      assign rating_value = yotpo_rating
      assign review_count = yotpo_count
    endif
  elsif schema_product.metafields.reviews.rating.value != blank and schema_product.metafields.reviews.rating_count != blank
    assign native_rating = schema_product.metafields.reviews.rating.value.rating | plus: 0
    assign native_count = schema_product.metafields.reviews.rating_count | plus: 0
    if native_rating > 0 and native_count > 0
      assign rating_value = native_rating
      assign review_count = native_count
    endif
  endif

  assign country_code = localization.country.iso_code | downcase
  assign market = 'us'

  case country_code
    when 'nl'
      assign market = 'nl'
    when 'fr'
      assign market = 'fr'
    when 'de'
      assign market = 'de'
    when 'gb', 'uk'
      assign market = 'uk'
    when 'us'
      assign market = 'us'
    else
      assign eu_countries = 'at,be,bg,hr,cy,cz,dk,ee,fi,gr,hu,ie,it,lv,lt,lu,mt,pl,pt,ro,sk,si,es,se' | split: ','
      if eu_countries contains country_code
        assign market = 'eu'
      else
        assign market = 'us'
      endif
  endcase

  if customer and customer.tags contains 'B2B Droppery' or customer.tags contains 'Roor B2B'
    assign market = 'b2b'
  endif
-%}
{% if schema_product != blank and schema_product.title != blank %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": {% if schema_product.variants.size > 1 %}"ProductGroup"{% else %}"Product"{% endif %},
      "@id": {{ schema_url | append: '#product' | json }},
      {% if schema_product.variants.size > 1 %}
        "productGroupID": "{{ schema_product.id }}",
      {% endif %}
      "url": {{ schema_url | json }},
      "name": {{ schema_product.title | strip_html | strip | json }},
      "description": {{ schema_product.description | strip_html | strip_newlines | strip | json }},
      {% if schema_variant.sku != blank %}
        "sku": {{ schema_variant.sku | json }},
      {% endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ schema_product.vendor | default: shop.name | json }}
      },
      {% if schema_product.featured_image %}
        "image": [
          {{ schema_product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
        ],
      {% endif %}
      {% if rating_value != blank and review_count > 0 %}
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ rating_value }}",
          "reviewCount": "{{ review_count }}"
        },
      {% endif %}
      {% if schema_product.variants.size > 1 %}
        "hasVariant": [
          {%- for variant in schema_product.variants -%}
            {%- liquid
              assign price_json = variant.metafields.membership.price
              assign member_price_value = ''

              if price_json != blank
                assign member_price_key = 'member_price_' | append: market
                assign member_price_value = price_json[member_price_key]
                
                if member_price_value == blank
                  assign member_price_search = member_price_key | append: '":"'
                  assign member_price_parts = price_json | split: member_price_search
                  if member_price_parts.size > 1
                    assign member_price_split = member_price_parts[1] | split: '"'
                    assign member_price_value = member_price_split[0]
                  endif
                endif
              endif

              if member_price_value != blank
                assign member_price_cents = member_price_value | times: 100
              else
                assign member_price_cents = 0
              endif
            -%}
            {
              "@type": "Product",
              "@id": {{ schema_url | append: '#variant_' | append: variant.id | json }},
              "name": {{ schema_product.title | append: ' - ' | append: variant.title | strip_html | strip | json }},
              "url": {{ shop.url | append: variant.url | json }},
              "sku": {{ variant.sku | json }},
              "image": [
                {{ variant.image | default: schema_product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
              ],
              "offers": [
                {
                  "@type": "Offer",
                  "priceCurrency": {{ schema_currency | json }},
                  "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
                  "priceValidUntil": {{ price_valid_until | json }},
                  "itemCondition": "https://schema.org/NewCondition",
                  "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
                  "seller": {
                    "@type": "Organization",
                    "name": {{ shop.name | json }}
                  },
                  "description": "Non-member price"
                }{% if member_price_cents > 0 %},
                {
                  "@type": "Offer",
                  "priceCurrency": {{ schema_currency | json }},
                  "price": "{{ member_price_cents | money_without_currency | replace: ',', '' }}",
                  "priceValidUntil": {{ price_valid_until | json }},
                  "itemCondition": "https://schema.org/NewCondition",
                  "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
                  "seller": {
                    "@type": "Organization",
                    "name": {{ shop.name | json }}
                  },
                  "description": "Member price"
                }{% endif %}
              ]
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      {% else %}
        "offers": [
          {%- for variant in schema_product.variants -%}
            {%- liquid
              assign price_json = variant.metafields.membership.price
              assign member_price_value = ''

              if price_json != blank
                assign member_price_key = 'member_price_' | append: market
                assign member_price_value = price_json[member_price_key]
                
                if member_price_value == blank
                  assign member_price_search = member_price_key | append: '":"'
                  assign member_price_parts = price_json | split: member_price_search
                  if member_price_parts.size > 1
                    assign member_price_split = member_price_parts[1] | split: '"'
                    assign member_price_value = member_price_split[0]
                  endif
                endif
              endif

              if member_price_value != blank
                assign member_price_cents = member_price_value | times: 100
              else
                assign member_price_cents = 0
              endif
            -%}
            {
              "@type": "Offer",
              "name": {{ schema_product.title | append: ' - ' | append: variant.title | strip_html | strip | json }},
              "url": {{ shop.url | append: variant.url | json }},
              "sku": {{ variant.sku | json }},
              "priceCurrency": {{ schema_currency | json }},
              "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
              "priceValidUntil": {{ price_valid_until | json }},
              "itemCondition": "https://schema.org/NewCondition",
              "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
              "seller": {
                "@type": "Organization",
                "name": {{ shop.name | json }}
              },
              "description": "Non-member price"
            }{% if member_price_cents > 0 %},
            {
              "@type": "Offer",
              "name": {{ schema_product.title | append: ' - ' | append: variant.title | strip_html | strip | json }},
              "url": {{ shop.url | append: variant.url | json }},
              "sku": {{ variant.sku | json }},
              "priceCurrency": {{ schema_currency | json }},
              "price": "{{ member_price_cents | money_without_currency | replace: ',', '' }}",
              "priceValidUntil": {{ price_valid_until | json }},
              "itemCondition": "https://schema.org/NewCondition",
              "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
              "seller": {
                "@type": "Organization",
                "name": {{ shop.name | json }}
              },
              "description": "Member price"
            }{% endif %}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      {% endif %}
    }
  </script>
{% endif %}